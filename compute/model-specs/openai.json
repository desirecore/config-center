      "spec": {
        "contextWindow": 400000,
        "maxOutputTokens": 128000,
        "capabilities": ["chat", "reasoning", "code", "vision", "long_context", "tool_use"],
        "serviceType": ["chat"],
        "defaultTemperature": 1,
        "supportsReasoning": true
      }
    },
