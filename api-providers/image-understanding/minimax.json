{
  "id": "minimax",
  "name": "MiniMax 图像理解（内测网关）",
  "capability": "image_understanding",
  "enabled": false,
  "builtin": true,
  "priority": 30,
  "endpoint": "${baseUrl}/understand_image",
  "method": "POST",
  "baseUrlRef": "internal-testing",
  "auth": { "type": "bearer" },
  "request": {
    "imageMode": "url",
    "bodyTemplate": { "prompt": "${prompt}", "image_url": "${imageUrl}" }
  },
  "response": { "textPath": "text" },
  "timeoutMs": 30000
}
